---
import BaseLayout from '../layouts/BaseLayout.astro'
import Contact from './Contact.jsx'
import { CLIENT } from '../config/client.js'
---
<BaseLayout
  title={`Contacto | ${CLIENT.name}`}
  description={`Contacta con ${CLIENT.name}. ${CLIENT.phone} · ${CLIENT.email}`}
  canonical={`https://${CLIENT.domain}/contacto`}
>
  <Contact client:load />
</BaseLayout>
