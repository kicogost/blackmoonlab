---
// AEO: populate faqs from BRIEF.md SERVICE_FAQ_* fields. Minimum 4 questions per service page.
/**
 * FAQ.astro — Visible FAQ accordion + FAQPage JSON-LD schema in one component.
 * Use this on every service page. The visible UI and the schema are always
 * driven from the same data source so they can never go out of sync.
 *
 * Props:
 *   faqs  Array<{ question: string, answer: string }>
 *
 * Usage:
 *   <FAQ faqs={faqs} client:load />
 *
 * Questions should be phrased exactly as a customer would ask a voice assistant
 * or AI tool. Example: "¿Cuánto cuesta la depilación láser en Madrid?"
 */

import FAQSchema from './FAQSchema.astro'
import FAQAccordion from './FAQ.jsx'

interface Props {
  faqs?: Array<{ question: string; answer: string }>
}

const { faqs } = Astro.props

// Map { question, answer } → { q, a } for the React accordion component.
const items = (faqs ?? []).map(({ question, answer }) => ({ q: question, a: answer }))
---

{faqs && faqs.length > 0 && (
  <>
    <FAQSchema faqs={faqs} />
    <FAQAccordion items={items} client:load />
  </>
)}
